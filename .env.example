# OpenRouter (or any OpenAI-compatible endpoint, e.g. local LM Studio)
# Get a key at https://openrouter.ai/keys (or use sk-... for OpenAI directly)
OPENAI_API_KEY=sk-or-v1-REPLACE-WITH-YOUR-KEY
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# For local LM Studio instead, leave OPENAI_API_KEY blank and:
# OPENAI_BASE_URL=http://localhost:1234/v1

# Optional: xeno-canto API key for audio-bench expansion via wildlife recordings.
# Get one at https://xeno-canto.org/account
XENOCANTO_API_KEY=
